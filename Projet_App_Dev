/// Modèle de données pour un Étudiant.
class Student {
  final int id;
  final String name;
  final int? score;

  Student({required this.id, required this.name, this.score});
}

/// États de navigation de l'application.
enum Screen { welcome, calculator }

/// Logique de calcul du Grade (Note).
String getGrade(int score) {
  if (score >= 90) return 'A';
  if (score >= 80) return 'B';
  if (score >= 70) return 'C';
  if (score >= 60) return 'D';
  return 'F';
}

/// Formate le message de résultat d'un étudiant pour le partage.
String formatStudentGrade(Student student) {
  if (student.score != null) {
    return "${student.name} marqué ${student.score} : Grade ${getGrade(student.score!)}";
  }
  return "Pas de score pour ${student.name}";
}

