class GradeCalculatorScreen extends StatefulWidget {
  final VoidCallback onBack;
  const GradeCalculatorScreen({super.key, required this.onBack});

  @override
  State<GradeCalculatorScreen> createState() => _GradeCalculatorScreenState();
}

class _GradeCalculatorScreenState extends State<GradeCalculatorScreen> {
  final List<Student> _students = [
    Student(id: 1, name: "Alice", score: 95),
    Student(id: 2, name: "Bob", score: 82),
    Student(id: 3, name: "Charlie", score: null),
    Student(id: 4, name: "Diana", score: 47),
  ];

  Future<void> _pickFile() async {
    FilePickerResult? result = await FilePicker.platform.pickFiles(type: FileType.any);
    if (result != null) {
      try {
        final file = File(result.files.single.path!);
        final lines = await file.readAsLines();
        List<Student> newEntries = [];

        for (var i = 0; i < lines.length; i++) {
          final line = lines[i];
          final parts = line.split(",");
          if (parts.isNotEmpty) {
            final name = parts[0].trim();
            final score = parts.length > 1 ? int.tryParse(parts[1].trim()) : null;
            if (name.isNotEmpty) {
              newEntries.add(Student(
                id: DateTime.now().millisecondsSinceEpoch + i,
                name: name,
                score: score,
              ));
            }
          }
        }

        if (newEntries.isNotEmpty) {
          setState(() => _students.addAll(newEntries));
          if (mounted) {
            ScaffoldMessenger.of(context).showSnackBar(
              SnackBar(content: Text("${newEntries.length} étudiants importés")),
            );
          }
        }
      } catch (e) {
        if (mounted) {
          ScaffoldMessenger.of(context).showSnackBar(
            const SnackBar(content: Text("Erreur lors de l'importation")),
          );
        }
      }
    }
  }

  void _shareText(String text) {
    Share.share(text);
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text("Calculateur", style: TextStyle(fontWeight: FontWeight.bold)),
        leading: IconButton(
          icon: const Icon(Icons.arrow_back),
          onPressed: widget.onBack,
        ),
        actions: [
          IconButton(icon: const Icon(Icons.upload_file), onPressed: _pickFile),
          IconButton(
            icon: const Icon(Icons.send),
            onPressed: () {
              final shareContent = "📊 Rapport global des Grades :\n\n" +
                  _students.map((s) => formatStudentGrade(s)).join("\n");
              _shareText(shareContent);
            },
          ),
        ],
      ),
      floatingActionButton: FloatingActionButton(
        onPressed: () => _showAddDialog(),
        child: const Icon(Icons.add),
      ),
      body: _students.isEmpty
          ? const Center(child: Text("Aucun étudiant. Ajoutez-en un !"))
          : ListView.separated(
              padding: const EdgeInsets.all(16),
              itemCount: _students.length,
              separatorBuilder: (_, __) => const SizedBox(height: 12),
              itemBuilder: (context, index) {
                final student = _students[index];
                return StudentCard(
                  student: student,
                  onDelete: () => setState(() => _students.remove(student)),
                  onShare: () => _shareText(formatStudentGrade(student)),
                );
              },
            ),
    );
  }

  void _showAddDialog() {
    showDialog(
      context: context,
      builder: (context) => AddStudentDialog(
        onAdd: (name, score) {
          setState(() {
            _students.add(Student(
              id: DateTime.now().millisecondsSinceEpoch,
              name: name,
              score: score,
            ));
          });
        },
      ),
    );
  }
}

class AddStudentDialog extends StatefulWidget {
  final Function(String, int?) onAdd;
  const AddStudentDialog({super.key, required this.onAdd});

  @override
  State<AddStudentDialog> createState() => _AddStudentDialogState();
}

class _AddStudentDialogState extends State<AddStudentDialog> {
  final _nameController = TextEditingController();
  final _scoreController = TextEditingController();

  @override
  Widget build(BuildContext context) {
    return AlertDialog(
      title: const Text("Nouvel Étudiant"),
      content: Column(
        mainAxisSize: MainAxisSize.min,
        children: [
          TextField(
            controller: _nameController,
            decoration: const InputDecoration(labelText: "Nom", border: OutlineInputBorder()),
            onChanged: (_) => setState(() {}),
          ),
          const SizedBox(height: 12),
          TextField(
            controller: _scoreController,
            decoration: const InputDecoration(labelText: "Score (facultatif)", border: OutlineInputBorder()),
            keyboardType: TextInputType.number,
          ),
        ],
      ),
      actions: [
        TextButton(onPressed: () => Navigator.pop(context), child: const Text("Annuler")),
        ElevatedButton(
          onPressed: _nameController.text.isEmpty
              ? null
              : () {
                  widget.onAdd(_nameController.text, int.tryParse(_scoreController.text));
                  Navigator.pop(context);
                },
          child: const Text("Ajouter"),
        ),
      ],
    );
  }
}

class StudentCard extends StatelessWidget {
  final Student student;
  final VoidCallback onDelete;
  final VoidCallback onShare;

  const StudentCard({
    super.key,
    required this.student,
    required this.onDelete,
    required this.onShare,
  });

  @override
  Widget build(BuildContext context) {
    final statusText = student.score != null
        ? "Score : ${student.score} • Grade : ${getGrade(student.score!)}"
        : "Pas de score pour ${student.name}";

    return Card(
      elevation: 4,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(24)),
      child: Padding(
        padding: const EdgeInsets.all(20.0),
        child: Row(
          children: [
            Expanded(
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Text(
                    student.name,
                    style: Theme.of(context).textTheme.titleLarge?.copyWith(fontWeight: FontWeight.bold),
                  ),
                  Text(
                    statusText,
                    style: TextStyle(
                      color: student.score == null
                          ? Theme.of(context).colorScheme.error
                          : Theme.of(context).colorScheme.primary,
                    ),
                  ),
                ],
              ),
            ),
            IconButton(
              icon: const Icon(Icons.share, color: Colors.blue),
              onPressed: onShare,
            ),
            IconButton(
              icon: const Icon(Icons.delete, color: Colors.red),
              onPressed: onDelete,
            ),
          ],
        ),
      ),
    );
  }
}
